{
  "expo": {
    "name": "Ricebowland",
    "slug": "Ricebowland",
    "version": "1.0.0",
    "scheme": "ricebowland",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.sutanmerah.Ricebowland",
      "versionCode": 1,
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true, // Sangat krusial agar Android memverifikasi link ini secara otomatis
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ],
          "data": [
            {
              "scheme": "http"
            },
            {
              "scheme": "https"
            },
            {
              "host": "ricebowland.42web.io"
            },
            {
              "pathPrefix": "/dashboard"
            }
          ]
        }
      ]
    },

    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "70f5cfa9-f134-4581-96bf-831bfa36f0ed"
      }
    }
  }
}
